@page
@model WheelsRental.Pages.Reservas.IndexModel
@{
    ViewData["Title"] = "Reservas";
}

<h2>Reservas</h2>
<p><a class="btn" asp-page="Create">+ Realizar reserva</a></p>

<table>
    <tr><th>Id</th><th>Cliente</th><th>Bicicleta</th><th>Reserva</th><th>Retirada prevista</th><th>Status</th></tr>
    @foreach (var r in Model.Reservas)
    {
        <tr>
            <td>@r.Id</td>
            <td>@Model.NomeCliente(r.ClienteId)</td>
            <td>@Model.NomeBike(r.BicicletaId)</td>
            <td>@r.DataReserva.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@r.DataRetiradaPrevista.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@r.Status</td>
        </tr>
    }
</table>
