<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Wheels</title>
    <style>
        :root { --azul: #2E5C8A; --azulclaro: #EAF2FB; }
        * { box-sizing: border-box; }
        body { font-family: Segoe UI, Arial, sans-serif; margin: 0; color: #222; background: #f6f8fb; }
        header { background: var(--azul); color: #fff; padding: 14px 28px; }
        header h1 { margin: 0; font-size: 22px; }
        nav { background: #fff; border-bottom: 1px solid #dde6f0; padding: 8px 28px; }
        nav a { color: var(--azul); text-decoration: none; margin-right: 18px; font-weight: 600; }
        nav a:hover { text-decoration: underline; }
        main { padding: 24px 28px; max-width: 1000px; }
        h2 { color: var(--azul); }
        table { border-collapse: collapse; width: 100%; background: #fff; }
        th, td { border: 1px solid #dde6f0; padding: 8px 10px; text-align: left; font-size: 14px; }
        th { background: var(--azulclaro); color: #15314f; }
        .btn { display: inline-block; background: var(--azul); color: #fff; padding: 8px 14px;
               border-radius: 5px; text-decoration: none; border: none; cursor: pointer; font-size: 14px; }
        .btn:hover { background: #24496e; }
        .card { background: #fff; border: 1px solid #dde6f0; border-radius: 8px; padding: 18px; margin-bottom: 18px; }
        label { display: block; margin: 10px 0 4px; font-weight: 600; }
        input, select { width: 100%; padding: 8px; border: 1px solid #ccd6e0; border-radius: 5px; }
        .msg { background: #e7f6ec; border: 1px solid #b6e0c4; padding: 10px; border-radius: 6px; margin-bottom: 14px; }
    </style>
</head>
<body>
    <header><h1>🚲 Sistema de Aluguel de Bicicletas Wheels</h1></header>
    <nav>
        <a asp-page="/Index">Início</a>
        <a asp-page="/Bicicletas/Index">Bicicletas</a>
        <a asp-page="/Clientes/Index">Clientes</a>
        <a asp-page="/Alugueis/Index">Aluguéis</a>
        <a asp-page="/Reservas/Index">Reservas</a>
        <a asp-page="/Manutencao/Index">Manutenção</a>
    </nav>
    <main>
        @RenderBody()
    </main>
</body>
</html>
