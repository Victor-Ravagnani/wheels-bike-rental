@page
@model ErrorModel
@{
    ViewData["Title"] = "Erro";
}
<h2>Ocorreu um erro</h2>
<div class="card">
    <p>Desculpe, algo deu errado ao processar a sua solicitação.</p>
    @if (!string.IsNullOrEmpty(Model.RequestId)) { <p><strong>ID da requisição:</strong> @Model.RequestId</p> }
    <p><a class="btn" asp-page="/Index">Voltar ao início</a></p>
</div>
